# 3X-UI panel base URL. Include the custom web base path if your panel uses one.
XUI_URI=http://127.0.0.1:2053

# Panel login credentials.
XUI_USERNAME=admin
XUI_PASSWORD=admin

# Xray-core expvar metrics endpoint. Leave empty to disable Xray metrics.
XRAY_METRICS_URI=http://127.0.0.1:11111/debug/vars

# Address the exporter listens on.
LISTEN_ADDR=:9808

# HTTP path that serves Prometheus metrics.
METRICS_PATH=/metrics

# Per-request timeout for outbound HTTP calls.
HTTP_TIMEOUT=10s

# Set to true to skip TLS verification when the panel uses a self-signed cert.
INSECURE_SKIP_VERIFY=false
