# 3X-UI panel base URL. Include the custom web base path if your panel uses one,
# e.g. http://127.0.0.1:2053/myrandompath  (no trailing /panel, no trailing slash needed).
XUI_URI=http://127.0.0.1:2053

# --- Authentication: pick ONE method ---
#
# RECOMMENDED (3X-UI v3+): an API token from Settings -> Security -> API Token.
# It is sent as a Bearer token and bypasses the panel's CSRF protection, so it
# works without a /login step. When set, XUI_USERNAME/XUI_PASSWORD are ignored.
XUI_API_TOKEN=

# Fallback: panel login credentials (only used when XUI_API_TOKEN is empty).
# On v3+ the exporter performs the required CSRF handshake automatically.
XUI_USERNAME=admin
XUI_PASSWORD=admin

# Xray-core expvar metrics endpoint. Leave empty to disable Xray metrics.
XRAY_METRICS_URI=http://127.0.0.1:11111/debug/vars

# Address the exporter listens on.
LISTEN_ADDR=:9808

# HTTP path that serves Prometheus metrics.
METRICS_PATH=/metrics

# Per-request timeout for outbound HTTP calls.
HTTP_TIMEOUT=10s

# Set to true to skip TLS verification when the panel uses a self-signed cert.
INSECURE_SKIP_VERIFY=false
