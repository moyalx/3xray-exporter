# Grafana admin login (change the password!).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Optional: Grafana's public URL. MUST include the scheme and a trailing slash.
#   - Behind a domain/reverse proxy:  GF_ROOT_URL=https://grafana.example.com/
#   - Direct IP access:               GF_ROOT_URL=http://<server-ip>:3000/
# Leave EMPTY for direct IP access. NEVER use a bare hostname (e.g. just
# "grafana.example.com") — Grafana treats it as a path and you get an infinite
# /host/host/.../login redirect loop.
GF_ROOT_URL=

# Prometheus data retention.
PROM_RETENTION=30d
