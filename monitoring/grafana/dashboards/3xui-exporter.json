{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["3x-ui", "xray", "vpn"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "3X-UI Exporter",
  "uid": "3xui-exporter",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "datasource": null,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Exporter Up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xui_exporter_up" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Online Users",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xui_users_online_total" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Enabled Clients",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(xui_user_enabled == 1)", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Traffic (used)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(xui_inbound_up_bytes) + sum(xui_inbound_down_bytes)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Online users over time",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xui_users_online_total", "legendFormat": "online" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" } }, "overrides": [] }
    },

    {
      "id": 101,
      "type": "row",
      "title": "Outbounds",
      "collapsed": false,
      "datasource": null,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "panels": []
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Avg outbound latency",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(xray_observatory_outbound_delay_ms)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 } ] } }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Max outbound latency",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(xray_observatory_outbound_delay_ms)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 700 } ] } }, "overrides": [] }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Min outbound latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "min(xray_observatory_outbound_delay_ms)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Outbounds Alive",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(xray_observatory_outbound_alive)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Outbound status (per outbound)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xray_observatory_outbound_alive", "legendFormat": "{{outbound_tag}}", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "ALIVE", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Outbound latency per outbound (+ average)",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xray_observatory_outbound_delay_ms", "legendFormat": "{{outbound_tag}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(xray_observatory_outbound_delay_ms)", "legendFormat": "average" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "average" }, "properties": [ { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [ 8, 6 ] } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] }
        ]
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "Average outbound latency over time",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(xray_observatory_outbound_delay_ms)", "legendFormat": "avg latency" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(xray_observatory_outbound_delay_ms)", "legendFormat": "max latency" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "min(xray_observatory_outbound_delay_ms)", "legendFormat": "min latency" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 26,
      "type": "state-timeline",
      "title": "Outbound up/down over time",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xray_observatory_outbound_alive", "legendFormat": "{{outbound_tag}}" }
      ],
      "options": { "showValue": "never", "mergeValues": true, "alignValue": "center", "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "ALIVE", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Clients & Traffic",
      "collapsed": false,
      "datasource": null,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Inbound throughput (per inbound)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(xui_inbound_down_bytes[$__rate_interval])", "legendFormat": "{{inbound_tag}} down" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(xui_inbound_up_bytes[$__rate_interval])", "legendFormat": "{{inbound_tag}} up" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top 20 clients by traffic used",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(20, max by (email) (xui_user_traffic_used_bytes))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": {}, "renameByName": { "email": "Client", "Value": "Used" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Used", "desc": true } ] } }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "Used" }, "properties": [ { "id": "unit", "value": "bytes" } ] } ] }
    },

    {
      "id": 103,
      "type": "row",
      "title": "Xray Engine",
      "collapsed": false,
      "datasource": null,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Xray-core memory",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xray_core_memory_alloc_bytes", "legendFormat": "alloc" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xray_core_memory_sys_bytes", "legendFormat": "sys" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "xray_core_memory_heap_inuse_bytes", "legendFormat": "heap in-use" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    }
  ]
}
